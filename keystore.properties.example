# Example Keystore configuration for local release signing
# Copy this file to a new file named "keystore.properties" and fill in your actual credentials.
# DO NOT commit "keystore.properties" to version control! (It is ignored in .gitignore).

storeFile=../uliveto-release.keystore
storePassword=your_keystore_password
keyAlias=uliveto-key
keyPassword=your_key_password
